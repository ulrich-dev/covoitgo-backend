{
  "name": "covoitgo-backend",
  "version": "1.0.0",
  "description": "API backend Covoitgo — Node.js + Express + PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "psql -U postgres -d covoitgo -f db/schema.sql",
    "db:migrate": "psql -U postgres -d covoitgo -f db/migration_auth.sql",
    "db:migrate:oauth": "psql -U postgres -d covoitgo -f db/migration_oauth.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.9",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.3",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.0",
    "jsonwebtoken": "^9.0.2",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}