# ════════════════════════════════════════════════════════════════
#  Covoitgo — Configuration Backend  (copiez en .env)
# ════════════════════════════════════════════════════════════════

# ── Base de données ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=covoitgo
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe

# ── Session ──────────────────────────────────────────────────
SESSION_SECRET=changez_cette_valeur_minimum_32_caracteres

# ── Environnement ────────────────────────────────────────────
NODE_ENV=development

# ── URLs ─────────────────────────────────────────────────────
# Le backend reste toujours sur localhost.
# Les appareils externes (mobile, tablette) passent par le proxy Vite.
# → Il n'est plus nécessaire de changer ces URLs pour le réseau local.
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# ── Emails (Mailtrap dev) ────────────────────────────────────
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=votre_user_mailtrap
MAILTRAP_PASS=votre_pass_mailtrap

# ── OAuth Google ─────────────────────────────────────────────
# URI de redirection à enregistrer dans Google Console :
#   http://localhost:5000/api/auth/google/callback
GOOGLE_CLIENT_ID=votre_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-votre_secret

# ── OAuth Facebook ───────────────────────────────────────────
# URI de redirection à enregistrer dans Facebook :
#   http://localhost:5000/api/auth/facebook/callback
FACEBOOK_APP_ID=votre_facebook_app_id
FACEBOOK_APP_SECRET=votre_facebook_app_secret
