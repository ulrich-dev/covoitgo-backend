<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <!-- Autoriser les connexions HTTPS vers Railway et Vercel -->
  <domain-config cleartextTrafficPermitted="false">
    <domain includeSubdomains="true">railway.app</domain>
    <domain includeSubdomains="true">vercel.app</domain>
    <domain includeSubdomains="true">clando.online</domain>
  </domain-config>

  <!-- Autoriser HTTP uniquement en développement local -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="true">localhost</domain>
    <domain includeSubdomains="true">10.0.2.2</domain>
    <domain includeSubdomains="true">192.168.0.0</domain>
  </domain-config>
</network-security-config>
